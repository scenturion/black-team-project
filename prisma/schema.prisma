generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  STUDENT
}

enum StudentStatus {
  PENDING_APPROVAL
  ACTIVE
  INACTIVE
}

enum Sex {
  MASCULINO
  FEMENINO
  OTRO
}

enum DayOfWeek {
  LUNES
  MARTES
  MIERCOLES
  JUEVES
  VIERNES
  SABADO
  DOMINGO
}

enum SessionStatus {
  ACTIVE
  CANCELLED
  MODIFIED
}

enum BookingStatus {
  RESERVED
  CANCELLED_BY_STUDENT
  CANCELLED_BY_ADMIN
  ATTENDED
  ABSENT
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DocumentType {
  APTO_FISICO
  DESLINDE_CONSENTIMIENTO
  AUTORIZACION_TUTOR
  OTRO
}

enum DocumentStatus {
  PENDING
  APPROVED
  EXPIRED
}

enum NotificationType {
  PAYMENT_DUE
  PAYMENT_PENDING_REVIEW
  PAYMENT_APPROVED
  PAYMENT_REJECTED
  CLASS_REMINDER
  CLASS_CANCELLED
  CLASS_MODIFIED
  DOCUMENT_EXPIRING
  DOCUMENT_MISSING
  STUDENT_APPROVED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      Role
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student               Student?
  notifications         Notification[]
  auditLogs             AuditLog[]      @relation("AuditCreator")
  approvedStudents      Student[]       @relation("ApprovedBy")
  reviewedPayments      Payment[]       @relation("PaymentReviewer")
  reviewedDocuments     Document[]      @relation("DocumentReviewer")
  modifiedSessions      ClassSession[]  @relation("SessionModifier")
  correctedAttendances  Attendance[]    @relation("AttendanceCorrector")
  assignedPlans         StudentPlan[]   @relation("PlanAssigner")
  invitations           Invitation[]    @relation("InvitationCreator")
}

model Student {
  id                   String        @id @default(cuid())
  userId               String        @unique
  user                 User          @relation(fields: [userId], references: [id])
  firstName            String
  lastName             String
  birthDate            DateTime
  sex                  Sex
  phone                String?
  dni                  String?       @unique
  belt                 String        @default("BLANCO")
  beltGrade            Int           @default(0)
  weight               Float?
  medicalNotes         String?
  allergiesAndInjuries String?
  emergencyContactName String
  emergencyContactPhone String
  status               StudentStatus @default(PENDING_APPROVAL)
  termsAcceptedAt      DateTime?
  isMinor              Boolean       @default(false)
  beltLockedByAdmin    Boolean       @default(false)
  approvedById         String?
  approvedBy           User?         @relation("ApprovedBy", fields: [approvedById], references: [id])
  approvedAt           DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  guardian    Guardian?
  plans       StudentPlan[]
  bookings    Booking[]
  payments    Payment[]
  documents   Document[]
  attendances Attendance[]
}

model Guardian {
  id           String   @id @default(cuid())
  studentId    String   @unique
  student      Student  @relation(fields: [studentId], references: [id])
  firstName    String
  lastName     String
  email        String?
  phone        String
  relationship String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Plan {
  id                String  @id @default(cuid())
  name              String
  description       String?
  monthlyPrice      Float
  classesPerWeek    Int?
  allowsFreeBooking Boolean @default(true)
  allowsReplacement Boolean @default(true)
  allowsFixedGroup  Boolean @default(false)
  maxActiveBookings Int?
  isActive          Boolean @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  studentPlans   StudentPlan[]
  classSchedules ClassSchedulePlan[]
}

model StudentPlan {
  id           String    @id @default(cuid())
  studentId    String
  student      Student   @relation(fields: [studentId], references: [id])
  planId       String
  plan         Plan      @relation(fields: [planId], references: [id])
  startDate    DateTime
  endDate      DateTime?
  assignedById String
  assignedBy   User      @relation("PlanAssigner", fields: [assignedById], references: [id])
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model ClassSchedule {
  id          String    @id @default(cuid())
  name        String
  description String?
  dayOfWeek   DayOfWeek
  startTime   String
  duration    Int
  maxCapacity Int
  isActive    Boolean   @default(true)
  validFrom   DateTime
  validUntil  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  sessions ClassSession[]
  plans    ClassSchedulePlan[]
}

model ClassSchedulePlan {
  id              String        @id @default(cuid())
  classScheduleId String
  classSchedule   ClassSchedule @relation(fields: [classScheduleId], references: [id])
  planId          String
  plan            Plan          @relation(fields: [planId], references: [id])

  @@unique([classScheduleId, planId])
}

model ClassSession {
  id              String        @id @default(cuid())
  classScheduleId String
  classSchedule   ClassSchedule @relation(fields: [classScheduleId], references: [id])
  date            DateTime
  startTime       String?
  duration        Int?
  maxCapacity     Int?
  status          SessionStatus @default(ACTIVE)
  cancelReason    String?
  modifiedById    String?
  modifiedBy      User?         @relation("SessionModifier", fields: [modifiedById], references: [id])
  modifiedAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  bookings    Booking[]
  attendances Attendance[]

  @@unique([classScheduleId, date])
}

model Booking {
  id             String        @id @default(cuid())
  studentId      String
  student        Student       @relation(fields: [studentId], references: [id])
  classSessionId String
  classSession   ClassSession  @relation(fields: [classSessionId], references: [id])
  status         BookingStatus @default(RESERVED)
  weekStart      DateTime
  bookedAt       DateTime      @default(now())
  cancelledAt    DateTime?
  cancelledBy    String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([studentId, classSessionId])
}

model Attendance {
  id             String       @id @default(cuid())
  studentId      String
  student        Student      @relation(fields: [studentId], references: [id])
  classSessionId String
  classSession   ClassSession @relation(fields: [classSessionId], references: [id])
  present        Boolean
  correctedById  String?
  correctedBy    User?        @relation("AttendanceCorrector", fields: [correctedById], references: [id])
  correctedAt    DateTime?
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([studentId, classSessionId])
}

model Payment {
  id              String        @id @default(cuid())
  studentId       String
  student         Student       @relation(fields: [studentId], references: [id])
  period          String
  amount          Float?
  status          PaymentStatus @default(PENDING)
  voucherPath     String?
  notes           String?
  submittedAt     DateTime      @default(now())
  reviewedAt      DateTime?
  reviewedById    String?
  reviewedBy      User?         @relation("PaymentReviewer", fields: [reviewedById], references: [id])
  rejectionReason String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Document {
  id           String         @id @default(cuid())
  studentId    String
  student      Student        @relation(fields: [studentId], references: [id])
  type         DocumentType
  filename     String
  path         String
  uploadedAt   DateTime       @default(now())
  expiresAt    DateTime?
  status       DocumentStatus @default(PENDING)
  reviewedById String?
  reviewedBy   User?          @relation("DocumentReviewer", fields: [reviewedById], references: [id])
  reviewedAt   DateTime?
  notes        String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model Notification {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id])
  type        NotificationType
  title       String
  body        String
  isRead      Boolean          @default(false)
  emailSentAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation("AuditCreator", fields: [userId], references: [id])
  action     String
  entityType String
  entityId   String
  before     Json?
  after      Json?
  createdAt  DateTime @default(now())
}

model SystemConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Invitation {
  id          String    @id @default(cuid())
  token       String    @unique @default(cuid())
  used        Boolean   @default(false)
  usedAt      DateTime?
  createdById String
  createdBy   User      @relation("InvitationCreator", fields: [createdById], references: [id])
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
}
